{
  "name": "socrate-ui",
  "version": "1.0.0",
  "description": "Socrate AI Teaching System",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd frontend && npm run dev -- --port 5173",
    "build": "cd frontend && npm run build",
    "setup-data": "bash setup-data.sh"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-fileupload": "^1.4.3",
    "gray-matter": "^4.0.3",
    "concurrently": "^8.2.2"
  }
}
